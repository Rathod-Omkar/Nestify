<% layout("/layouts/boilerplate")%>

<div class="row mt-4 mb-5">
    <div class="col-lg-8 offset-lg-2">
        <h2 class="mb-4">Add Admin</h2>

        <% if (error) { %>
            <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>

        <form action="/admin/admins" method="POST">
            <div class="mb-3">
                <label class="form-label" for="username">Name</label>
                <input type="text" name="admin[username]" id="username" class="form-control" required>
            </div>

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input type="email" name="admin[email]" id="email" class="form-control" required>
            </div>

            <div class="mb-4">
                <label class="form-label" for="password">Temporary Password</label>
                <input type="password" name="admin[password]" id="password" class="form-control" required>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-dark">Create Admin</button>
                <a href="/admin/admins" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
