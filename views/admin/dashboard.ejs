<% layout("/layouts/boilerplate")%>

    <div class="row mt-4 mb-5">
        <div class="col-lg-10 offset-lg-1">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="mb-1">Admin Dashboard</h1>
                    <p class="text-muted mb-0">Welcome, <%= currAdmin.username %>
                    </p>
                </div>
                <!-- <form action="/admin/logout" method="POST">
                    <button class="btn btn-outline-danger" type="submit">Logout</button>
                </form> -->
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <div class="admin-stat">
                        <p class="text-muted mb-1">Listings</p>
                        <h3>
                            <%= listingCount %>
                        </h3>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="admin-stat">
                        <p class="text-muted mb-1">Users</p>
                        <h3>
                            <%= userCount %>
                        </h3>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="admin-stat">
                        <p class="text-muted mb-1">Admins</p>
                        <h3>
                            <%= adminCount %>
                        </h3>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="admin-stat">
                        <p class="text-muted mb-1">Rejected Listings</p>
                        <h3>
                            <%= rejectedListingCount %>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a href="/admin/listing-requests" class="btn btn-dark">Review Listings (<%= pendingListingCount %>)</a>
                <a href="/admin/users" class="btn btn-dark">Manage Users</a>
                <a href="/admin/admins" class="btn btn-dark">Manage Admins</a>
                <a href="/listings" class="btn btn-outline-secondary ms-2">View Listings</a>
            </div>

