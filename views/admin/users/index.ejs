<% layout("/layouts/boilerplate")%>

<div class="row mt-4 mb-5">
    <div class="col-lg-10 offset-lg-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">Manage Users</h1>
                <p class="text-muted mb-0"><%= users.length %> registered user<%= users.length !== 1 ? "s" : "" %></p>
            </div>
            <a href="/admin" class="btn btn-outline-secondary">Back to Dashboard</a>
        </div>

        <% if (users.length === 0) { %>
            <p class="text-muted">No users registered yet.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Listings</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (let user of users) { %>
                            <tr>
                                <td><%= user.username %></td>
                                <td><%= user.email %></td>
                                <td><%= user.gender || "-" %></td>
                                <td><%= user.phoneNumber || "-" %></td>
                                <td>
                                    <% const count = listingCountMap[user._id.toString()] || 0; %>
                                    <% if (count > 0) { %>
                                        <a href="/listings?userId=<%= user._id %>" class="badge text-bg-secondary text-decoration-none">
                                            <%= count %> listing<%= count !== 1 ? "s" : "" %>
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted">0</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a href="/admin/users/<%= user._id %>/listings" class="btn btn-outline-primary btn-sm">View All Listings</a>
                                        <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST"
                                            onsubmit="return confirm('Delete <%= user.username %>? This cannot be undone.')">
                                            <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>
