<% layout("/layouts/boilerplate")%>

<div class="row mt-4 mb-5">
    <div class="col-lg-8 offset-lg-2">
        <h1 class="mb-3">Contact Us</h1>
        <p class="lead">Have a question about Nestify? Send us a message and we will get back to you soon.</p>

        <form action="/contact" method="GET" class="mt-4">
            <div class="row">
                <div class="mb-3 col-md-6">
                    <label class="form-label" for="name">Name</label>
                    <input type="text" id="name" class="form-control" placeholder="Your name">
                </div>
                <div class="mb-3 col-md-6">
                    <label class="form-label" for="email">Email</label>
                    <input type="email" id="email" class="form-control" placeholder="you@example.com">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="subject">Subject</label>
                <input type="text" id="subject" class="form-control" placeholder="How can we help?">
            </div>

            <div class="mb-3">
                <label class="form-label" for="message">Message</label>
                <textarea id="message" class="form-control" rows="5" placeholder="Write your message"></textarea>
            </div>

            <button type="submit" class="btn btn-dark">Send Message</button>
        </form>

        <div class="row mt-5">
            <div class="col-md-4 mb-3">
                <h5>Email</h5>
                <p>support@nestify.com</p>
            </div>
            <div class="col-md-4 mb-3">
                <h5>Phone</h5>
                <p>+91 98765 43210</p>
            </div>
            <div class="col-md-4 mb-3">
                <h5>Location</h5>
                <p>Pune, India</p>
            </div>
        </div>
    </div>
</div>
