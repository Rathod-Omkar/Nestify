<% layout("/layouts/boilerplate.ejs") %>

<div class="dashboard-container container mt-5 mb-5">
    <!-- Hero Section -->
    <div class="row align-items-center mb-5 pb-3 border-bottom">
        <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
            <h1 class="dashboard-welcome display-4 fw-bold">Welcome back, <span class="text-primary"><%= currUser.username %></span></h1>
            <p class="dashboard-subtitle lead text-muted mt-3">What are you looking for today? Discover your next perfect stay or an authentic shared community.</p>
            <div class="quick-links mt-4">
                <a href="/listings/my-listings" class="text-decoration-none fw-semibold me-4"><i class="fa-solid fa-house-user me-2"></i>My Listings</a>
                <a href="/my-bookings" class="text-decoration-none fw-semibold"><i class="fa-solid fa-calendar-check me-2"></i>My Bookings</a>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="hero-graphic rounded-4 overflow-hidden shadow-sm" style="height: 280px; background: url('https://images.unsplash.com/photo-1449844908441-8829872d2607?auto=format&fit=crop&q=80&w=1200') center/cover;">
            </div>
        </div>
    </div>

    <!-- Choices / Grid -->
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold mb-0">Explore Nestify</h3>
        <a href="/listings" class="text-decoration-none fw-bold text-primary">View All Listings &rarr;</a>
    </div>

    <div class="row g-4">
        <!-- Private Listings Card -->
        <div class="col-md-6">
            <a href="/listings?category=normal" class="text-decoration-none">
                <div class="card-horizontal rounded-4 overflow-hidden position-relative shadow-sm" style="background: url('https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&q=80&w=800') center/cover; height: 260px;">
                    <div class="card-overlay position-absolute top-0 start-0 w-100 h-100 p-4 d-flex flex-column justify-content-end">
                        <h2 class="text-white fw-bold mb-1">Private Listings</h2>
                        <p class="text-white-50 mb-0">Private homes, apartments &amp; standalone properties.</p>
                    </div>
                </div>
            </a>
        </div>
        
        <!-- Co-Nest Card -->
        <div class="col-md-6">
            <a href="/listings?category=shared" class="text-decoration-none">
                <div class="card-horizontal rounded-4 overflow-hidden position-relative shadow-sm" style="background: url('https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&q=80&w=800') center/cover; height: 260px;">
                    <div class="card-overlay position-absolute top-0 start-0 w-100 h-100 p-4 d-flex flex-column justify-content-end">
                        <h2 class="text-white fw-bold mb-1">Co-Nest</h2>
                        <p class="text-white-50 mb-0">Cozy shared spaces &amp; community-style living.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .card-overlay {
        background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.8) 100%);
        transition: background 0.3s ease;
    }
    
    .card-horizontal {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card-horizontal:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.2) !important;
    }

    .card-horizontal:hover .card-overlay {
        background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.95) 100%);
    }

    .dashboard-welcome {
        letter-spacing: -0.02em;
    }

    .quick-links a {
        color: #4f46e5;
        transition: color 0.2s ease;
        font-size: 1.05rem;
    }
    
    [data-bs-theme="dark"] .quick-links a {
        color: #818cf8;
    }

    .quick-links a:hover {
        color: #3730a3;
    }

    [data-bs-theme="dark"] .quick-links a:hover {
        color: #a5b4fc;
    }
    
    [data-bs-theme="dark"] .dashboard-subtitle {
        color: #9ca3af !important;
    }
</style>