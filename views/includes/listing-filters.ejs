            <form action="/listings" method="GET" class="listing-filter-bar mb-4">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label" for="location">Location</label>
                        <input type="text" name="location" id="location" class="form-control"
                            value="<%= filters.location || "" %>" placeholder="City, country, title">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="minPrice">Min price</label>
                        <input type="number" name="minPrice" id="minPrice" class="form-control"
                            value="<%= filters.minPrice || "" %>">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="maxPrice">Max price</label>
                        <input type="number" name="maxPrice" id="maxPrice" class="form-control"
                            value="<%= filters.maxPrice || "" %>">
                    </div>

                    <div class="col-md-2">
                        <label class="form-label" for="womenSafetyRating">Women safety</label>
                        <select name="womenSafetyRating" id="womenSafetyRating" class="form-select">
                            <option value="">Any</option>
                            <% for (let rating=1; rating <=5; rating++) { %>
                                <option value="<%= rating %>" <%=Number(filters.womenSafetyRating)===rating ? "selected"
                                    : "" %>><%= rating %></option>
                                <% } %>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="category">Listing Type</label>
                        <select name="category" id="category" class="form-select">
                            <option value="">Any Type</option>
                            <option value="normal" <%= filters.category === 'normal' ? 'selected' : '' %>>Private (Normal)</option>
                            <option value="shared" <%= filters.category === 'shared' ? 'selected' : '' %>>Shared (Co-Nest)</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="checkIn">Check-in</label>
                        <input type="date" name="checkIn" id="checkIn" class="form-control"
                            value="<%= filters.checkIn || "" %>" min="<%= todayISO %>">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="checkOut">Check-out</label>
                        <input type="date" name="checkOut" id="checkOut" class="form-control"
                            value="<%= filters.checkOut || "" %>" min="<%= todayISO %>">
                    </div>

                    <%# Sustainability feature checkboxes %>
                        <div class="col-12">
                            <label class="form-label mb-1">Sustainability Features</label>
                            <div class="d-flex flex-wrap gap-2">
                                <% const selectedFeatures=[].concat(filters.features || []); %>
                                    <% for (let field of sustainabilityFields) { %>
                                        <div class="form-check form-check-inline mb-0">
                                            <input class="form-check-input" type="checkbox" name="features"
                                                id="feat-<%= field %>" value="<%= field %>"
                                                <%=selectedFeatures.includes(field) ? "checked" : "" %>
                                            >
                                            <label class="form-check-label" for="feat-<%= field %>">
                                                <%= sustainabilityLabels[field] %>
                                            </label>
                                        </div>
                                        <% } %>
                            </div>
                        </div>

                        <div class="col-md-3 d-flex gap-2">
                            <button type="submit" class="btn btn-dark">Search</button>
                            <a href="/listings" class="btn btn-outline-secondary">Clear</a>
                        </div>
                </div>
            </form>

            <%# Category tabs %>
                <div class="mb-3 d-flex gap-2">
                    <a href="/listings"
                        class="btn btn-sm <%= !filters.category ? 'btn-dark' : 'btn-outline-secondary' %>">All</a>
                    <a href="/listings?category=normal"
                        class="btn btn-sm <%= filters.category === 'normal' ? 'btn-dark' : 'btn-outline-secondary' %>">Normal</a>
                    <a href="/listings?category=shared"
                        class="btn btn-sm <%= filters.category === 'shared' ? 'btn-dark' : 'btn-outline-secondary' %>">Co-Nest
                        (Shared)</a>
                </div>
