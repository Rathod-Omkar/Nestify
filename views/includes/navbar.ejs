          <i class="fa-solid fa-moon" aria-hidden="true"></i>
        </button>
        <% if (currAdmin) { %>
          <a class="nav-link" href="/admin">Admin Dashboard</a>
          <a class="nav-link" href="/admin/listing-requests">Requests</a>
          <form action="/admin/logout" method="POST">
            <button class="nav-link btn btn-link text-bg-danger" type="submit">Logout</button>
          </form>
          <% } else if (currUser) { %>
