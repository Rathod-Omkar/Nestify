<% layout("/layouts/boilerplate.ejs") %>

    <body>
        <h1>All Listings</h1>

        <% const todayISO=new Date().toISOString().split("T")[0]; %>

        <%- include("../includes/listing-filters.ejs", { todayISO }) %>

                <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1">

                    <% for(let listing of allListings){ %>
                        <a href="/listings/<%= listing._id %>" class="listing-links">
                            <div class="card col">
                                <img src="<%= listing.image.url%>" class="card-img-top"
                                    alt="<%= listing.image.filename%>">
                                <div class="card-img-overlay"></div>
                                <div class="card-body">
                                    <% const womenSafetyRating=listing.womenSafetyRating &&
                                        listing.womenSafetyRating.average ?
                                        Math.round(listing.womenSafetyRating.average) : 0; %>
                                        <p class="card-text"><b>
                                                <%= listing.title %>
                                            </b> <br>
                                            <span class="text-muted small">
                                                📍 <%= [listing.location, listing.city, listing.state, listing.country].filter(Boolean).join(', ') %>
                                            </span> <br>
                                            &#8377; <%= listing.price.toLocaleString("en-IN") %>/night</p>
                                        <div class="listing-rating-lines">
                                            <span
                                                class="badge <%= listing.category === 'shared' ? 'text-bg-primary' : 'text-bg-light' %> me-1">
                                                <%= listing.category==='shared' ? 'Co-Nest' : 'Normal' %>
                                            </span>
                                            <span>Women safety <span class="rating-stars">
                                                    <%= "★" .repeat(womenSafetyRating) %>
                                                        <%= "☆" .repeat(5 - womenSafetyRating) %>
                                                </span></span>
                                        </div>
                                        <% if (listing.sustainabilityChecklist) { %>
                                            <div class="d-flex flex-wrap gap-1 mt-1">
                                                <% const sustainLabels = {
                                                    hasSolar: "Solar",
                                                    wasteSegregation: "Waste",
                                                    rainwaterHarvesting: "Rainwater",
                                                    energyEfficientAppliances: "Energy Eff.",
                                                    publicTransportAccess: "Public Transport",
                                                    waterSavingFixtures: "Water Saving"
                                                }; %>
                                                <% for (let [key, label] of Object.entries(sustainLabels)) { %>
                                                    <% if (listing.sustainabilityChecklist[key]) { %>
                                                        <span class="badge text-bg-success" style="font-size:0.65rem">
                                                            <%= label %>
                                                        </span>
                                                    <% } %>
                                                <% } %>
                                            </div>
                                        <% } %>
                                </div>
                            </div>
                        </a>

                        <% } %>

                </div>

    </body>

    <script>
        // Ensure checkout is always after checkin
        const checkInInput = document.getElementById("checkIn");
        const checkOutInput = document.getElementById("checkOut");
        const todayStr = "<%= todayISO %>";
        checkInInput.min = todayStr;
        checkOutInput.min = todayStr;
        checkInInput.addEventListener("change", function () {
            if (checkOutInput.value && checkOutInput.value <= checkInInput.value) {
                checkOutInput.value = "";
            }
            checkOutInput.min = checkInInput.value || todayStr;
        });
    </script>